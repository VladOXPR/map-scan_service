{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "types": [
      "expo"
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@cuub/shared": [
        "../../packages/shared/src"
      ],
      "@cuub/shared/*": [
        "../../packages/shared/src/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "../../node_modules"
  ]
}
